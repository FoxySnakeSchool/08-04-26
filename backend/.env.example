# Connexion BDD
DB_HOST=localhost
DB_PORT=3306
DB_USER=unitee_user
DB_PASSWORD=changeme
DB_NAME=unitee_veille

# Serveur
PORT=3001

# Email de veille (destinataire des notifications)
VEILLE_EMAIL=veille@unitee.com

# Rétention sauvegardes (jours)
BACKUP_RETENTION_DAYS=30

# Répertoire de sauvegarde (chemin absolu sur le serveur)
BACKUP_DIR=./backups

# Brevo (ex-Sendinblue) — API transactionnelle
# Obtenir la clé sur https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=